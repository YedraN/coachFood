# Gemini API key para generación de recetas con IA (https://aistudio.google.com/apikey)
GEMINI_API_KEY=tu-clave-de-gemini-aqui

# Stripe
STRIPE_SECRET_KEY=sk_live_tu-clave-secreta-stripe
STRIPE_WEBHOOK_SECRET=whsec_tu-webhook-secret
STRIPE_PRICE_ID=price_tu-price-id

# Supabase (service role para webhooks)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Puerto del servidor (opcional, default es 3000)
PORT=3000
