{
  "expo": {
    "name": "CoachFood",
    "slug": "coachfood",
    "version": "1.0.0",
    "scheme": "coachfood",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f6f4ef"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.coachfood.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Usamos la cámara para escanear códigos de barras de productos y obtener información nutricional."
      }
    },
    "android": {
      "package": "com.coachfood.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f6f4ef"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "coachfood" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Usamos la cámara para escanear códigos de barras de productos."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "c31406b8-0984-4588-90d7-3e3863d47782"
      }
    }
  }
}
