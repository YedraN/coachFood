# Stripe
STRIPE_SECRET_KEY=tu-clave-de-stripe
STRIPE_WEBHOOK_SECRET=tu-webhook-secret
STRIPE_PRICE_ID=tu-price-id

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
# Solo necesaria para webhooks de Stripe
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Puerto del servidor (opcional, default es 3000)
PORT=3000
